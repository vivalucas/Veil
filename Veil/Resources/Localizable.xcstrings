          }
        }
      }
    },
    "To switch profiles with Focus modes, add %@ as a Focus Filter in System Settings %@ Focus %@ [Mode] %@ Focus Filters. When a Focus mode deactivates, the display profile is automatically restored." : {
      "comment" : "A description of how to use Focus Filters to switch profiles.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "To switch profiles with Focus modes, add %1$@ as a Focus Filter in System Settings %2$@ Focus %3$@ [Mode] %4$@ Focus Filters. When a Focus mode deactivates, the display profile is automatically restored."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フォーカスモードでプロファイルを切り替えるには、システム設定 %2$@ フォーカス %3$@ [モード] %4$@ フォーカスフィルタで %1$@ をフォーカスフィルタとして追加してください。フォーカスモードが無効になると、ディスプレイプロファイルは自動的に復元されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "若要通过专注模式切换配置，请在“系统设置 %2$@ 专注模式 %3$@ [模式] %4$@ 专注模式过滤条件”中将 %1$@ 添加为专注模式过滤条件。当专注模式停用时，显示器配置会自动恢复。"
          }
        }
      }
