    "About" : {
      "comment" : "The \"About\" navigation identifier.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリについて"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "关于"
          }
        }
      }
    },
    "Absolutely no personal information is collected or stored." : {
      "comment" : "A description of how user data is handled by the app.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "個人情報は一切収集・保存されません。"
          }
