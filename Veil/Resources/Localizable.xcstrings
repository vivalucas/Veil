        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "圆头"
          }
        }
      }
    },
    "Run a shell or AppleScript file before or after a profile switch. Hooks fire on every apply path: manual button, hotkey, display auto-switch, and Focus Filter." : {
      "comment" : "A description of the purpose of the hooks.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロファイル切り替えの前後にシェルまたは AppleScript ファイルを実行します。手動ボタン、ホットキー、ディスプレイ自動切り替え、集中モードフィルタのどの適用経路でもフックが実行されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在配置切换前后运行 Shell 或 AppleScript 文件。无论通过手动按钮、热键、显示器自动切换还是专注模式过滤条件应用配置，钩子都会执行。"
          }
