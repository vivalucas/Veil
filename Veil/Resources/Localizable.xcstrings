            "state" : "translated",
            "value" : "自适应"
          }
        }
      }
    },
    "Add" : {
      "comment" : "A button that adds an app to the whitelist.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "追加"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "添加"
          }
        }
      }
    },
    "Add a Quit %@ item to the bottom of the secondary context menu." : {
      "comment" : "A description of a menu item that quits the app.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "セカンダリコンテキストメニューの一番下に「%@ を終了」項目を追加します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在二级上下文菜单底部添加“退出 %@”菜单项。"
          }
        }
      }
    },
    "Add Application Manually" : {
      "comment" : "A heading for the section where users can add apps manually.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "手動でアプリケーションを追加"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "手动添加应用"
          }
        }
      }
    },
    "Advanced" : {
      "comment" : "The \"Advanced\" section in the \"Settings\" interface.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "詳細"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "高级"
          }
        }
      }
    },
    "Allow" : {
      "comment" : "Button title for allowing the app to control Veil settings.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "許可"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许"
          }
        }
      }
    },
    "Allow \"%@\" to control %@ settings?" : {
      "comment" : "Title of the NSAlert confirmation dialog for first-time authorization.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Allow \"%1$@\" to control %2$@ settings?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%1$@」が「%2$@」の設定を制御することを許可しますか？"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许“%1$@”控制 %2$@ 设置吗？"
          }
        }
      }
    },
    "Allow external applications to read and modify %@ settings via veil:// URLs." : {
      "comment" : "A toggle that enables or disables the ability for external applications to read and modify \\(Constants.displayName) settings via veil:// URLs.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外部アプリが veil:// URL を使って %@ の設定を読み書きできるようにします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许外部应用通过 veil:// URL 读取并修改 %@ 设置。"
          }
        }
      }
    },
    "Always show hidden items" : {
      "comment" : "A toggle that allows users to configure whether hidden menu bar items should always be visible in the native menu bar on a particular display.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "非表示項目を常に表示"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "始终显示隐藏项目"
          }
        }
      }
    },
    "Always show hidden menu bar items in the menu bar on this display." : {
      "comment" : "A toggle that allows users to choose whether to always show hidden menu bar items on a specific display.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このディスプレイのメニューバーに非表示のメニューバー項目を常に表示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "始终在此显示器上显示隐藏的菜单栏项目。"
          }
        }
      }
    },
    "Always show the %@ Bar at the mouse pointer's location when it is shown using a hotkey." : {
      "comment" : "A toggle that lets users decide whether the location of the \\(Constants.displayName) Bar should be fixed at the mouse pointer's location when it is shown using a hotkey.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホットキーで表示する際は、%@ バーを常にマウスポインターの位置に表示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用热键显示时，始终在鼠标指针位置显示 %@ 栏。"
          }
        }
      }
    },
    "Always-Hidden" : {
      "comment" : "Localized string key for the \"Always-Hidden\" menu bar section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "常に非表示"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "永久隐藏"
          }
        }
      }
    },
    "Appearance" : {
      "comment" : "The localized string key for the \"Appearance\" section in the \"Settings\" interface.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外観"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "外观"
          }
        }
      }
    },
    "App Appearance" : {
      "comment" : "Label for the app window appearance preference picker.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリの外観"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用外观"
          }
        }
      }
    },
    "Apply" : {
      "comment" : "A button that applies the current value of a slider to a setting.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "適用"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用"
          }
        }
      }
    },
    "Apply a Veil menu bar profile when this Focus activates." : {
      "comment" : "Description of the \"Set Menu Bar Profile\" focus filter intent, including the category name.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "集中モードが有効になったときに、指定した Veil メニューバープロファイルを適用します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "专注模式启用时，应用指定的 Veil 菜单栏配置。"
          }
        }
      }
    },
    "Apply briefly relaunches apps with menu bar items so they pick up the new spacing. Setting takes effect when this display is the active menu bar display." : {
      "comment" : "Tooltip for the spacing row in the display settings pane.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「適用」をクリックすると、メニューバー項目を含むアプリが一時的に再起動され、新しい間隔が反映されます。この設定は、このディスプレイがアクティブなメニューバーのディスプレイのときに有効です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用后会短暂重启包含菜单栏项目的应用，使新间距生效。此设置会在该显示器成为当前菜单栏所在显示器时生效。"
          }
        }
      }
    },
    "Apply different settings based on the current system appearance." : {
      "comment" : "Label for a toggle that allows the user to choose whether to use different appearance settings based on the current system appearance.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のシステム外観に基づいて異なる設定を適用します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据当前系统外观应用不同设置。"
          }
        }
      }
    },
    "Apply the spacing for this display" : {
      "comment" : "A button that applies the spacing for a display.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このディスプレイに間隔を適用"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用此显示器间距"
          }
        }
      }
    },
    "apps %lld" : {
      "comment" : "Shows the number of whitelisted apps",
      "localizations" : {
        "en" : {
          "variations" : {
            "plural" : {
              "one" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld app"
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld apps"
                }
              }
            }
          }
        },
        "ja" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld 個のアプリ"
                }
              }
            }
          }
        },
        "zh-Hans" : {
          "variations" : {
            "plural" : {
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "%lld 个应用"
                }
              }
            }
          }
        }
      }
    },
    "Apps that request settings access will appear here after you approve them." : {
      "comment" : "A description of the whitelisted apps section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定へのアクセスをリクエストしたアプリは、承認後にここに表示されます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "申请设置访问权限的应用在获准后会显示在此处。"
          }
        }
