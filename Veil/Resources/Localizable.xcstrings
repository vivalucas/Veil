          "stringUnit" : {
            "state" : "translated",
            "value" : "在带刘海的显示器上使用 LCS 排序"
          }
        }
      }
    },
    "Use Option-click to open always-hidden section" : {
      "comment" : "A toggle that lets the user choose whether to use option-click to open the always-hidden section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Option キーを押しながらクリックして「常に非表示」セクションを開く"
