    },
    "Use LCS sorting on notched displays" : {
      "comment" : "A toggle that lets the user choose whether to use the LCS sorting algorithm for profile sorting on notched displays.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ノッチ付きディスプレイで LCS ソートを使用"
          }
