{
  "sourceLanguage" : "en",
  "strings" : {
    "(no script selected)" : {
      "comment" : "A placeholder displayed in the \"Path\" column of a hook row when no script is selected.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "（スクリプト未選択）"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "（未选择脚本）"
          }
        }
      }
    },
    "%@ %@ Section" : {
      "comment" : "A menu item title that toggles the visibility of a section in the menu bar. The argument is the name of the section.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ %@ セクション"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ %2$@ 区域"
          }
        }
      }
    },
    "%@ Bar" : {
      "comment" : "The title of the window displayed in the menu bar.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ バー"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 栏"
          }
        }
      }
    },
    "%@ can work in a limited mode without this permission." : {
      "comment" : "A callout box that explains that the app can work in a limited mode without a particular permission.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ はこの権限なしでも制限モードで動作できます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可以在没有此权限的情况下以受限模式运行。"
          }
        }
      }
    },
    "%@ cannot arrange menu bar items in automatically hidden menu bars." : {
      "comment" : "A view that shows a message when the menu bar layout can't be arranged in automatically hidden menu bars.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は自動的に非表示になるメニューバーではメニューバー項目を整理できません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 无法在自动隐藏菜单栏中排列菜单栏项目。"
          }
        }
      }
    },
    "%@ cannot edit the appearance of automatically hidden menu bars." : {
      "comment" : "A view that appears when the user tries to edit the appearance of a menu bar that the system has hidden automatically.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は自動的に非表示になるメニューバーの外観を編集できません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 无法修改自动隐藏菜单栏的外观。"
          }
        }
      }
    },
    "%@ icon" : {
      "comment" : "The text that will be displayed in the \"Location\" picker view for the Ice Bar.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ アイコン"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 图标"
          }
        }
      }
    },
    "%@ is currently running. Running multiple menu bar managers at the same time can cause display issues and unexpected behavior. Consider quitting %@ before using %@." : {
      "comment" : "A warning alert that appears when a conflicting menu bar manager is detected.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ is currently running. Running multiple menu bar managers at the same time can cause display issues and unexpected behavior. Consider quitting %2$@ before using %3$@."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ は現在実行中です。複数のメニューバーマネージャーを同時に実行すると、表示の問題や予期しない動作が発生する可能性があります。%3$@ を使用する前に %2$@ を終了することをおすすめします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ 正在运行。同时运行多个菜单栏管理器可能会导致显示问题和意外行为。建议在使用 %3$@ 前退出 %2$@。"
          }
        }
      }
    },
    "%@ is unresponsive. Until it is restarted, it cannot be moved. Movement of other menu bar items may also be affected until this is resolved." : {
      "comment" : "The informative text of the alert displayed when a menu bar item is unresponsive.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は応答していません。再起動するまで移動できません。この問題が解決するまで、他のメニューバー項目の移動にも影響が出る場合があります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 无响应。重启之前无法移动该菜单栏项目。在此问题解决之前，其他菜单栏项目的移动也可能受到影响。"
          }
        }
      }
    },
    "%@ needs this to:" : {
      "comment" : "A section within a permission box that lists the reasons why a particular permission is needed. The argument is the name of the app.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ がこれを必要とする理由："
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 需要此权限来："
          }
        }
      }
    },
    "%@ needs your permission to manage the menu bar." : {
      "comment" : "A paragraph explaining the app's purpose and its commitment to user privacy.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ がメニューバーを管理するには、権限が必要です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 需要您的授权以管理菜单栏。"
          }
        }
      }
    },
    "%@ Settings…" : {
      "comment" : "The title of the menu item that opens the settings window.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 設定…"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 设置…"
          }
        }
      }
    },
