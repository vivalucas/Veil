    },
    "Right-click in an empty area of the menu bar to display a minimal version of %@'s menu. Disable this setting if you encounter conflicts with other apps." : {
      "comment" : "A description of a feature that lets users access a simplified version of the menu bar when right-clicking in an empty area.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "メニューバーの空いている領域を右クリックすると、%@ のシンプルなメニューが表示されます。他のアプリと競合する場合はこの設定を無効にしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在菜单栏空白处单击鼠标右键，即可显示 %@ 的精简版菜单。如果与其他应用发生冲突，请禁用此设置。"
          }
        }
      }
    },
    "Round Cap" : {
      "comment" : "A description of a round-shaped menu bar end cap.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ラウンドキャップ"
