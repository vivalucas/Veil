      }
    },
    "When an app sends a veil:// URL to change settings, Veil checks if that app is whitelisted." : {
      "comment" : "A step in the process of how to use Veil.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリが veil:// URL を使用して設定変更をリクエストすると、Veil はそのアプリがホワイトリストに登録されているかを確認します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当应用发送 veil:// URL 来更改设置时，Veil 会检查该应用是否在白名单中。"
          }
        }
      }
    },
    "Whitelisted Applications" : {
      "comment" : "A heading for the list of whitelisted apps.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホワイトリストに登録されたアプリ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "白名单应用"
          }
        }
      }
    },
    "Whitelisted apps can read settings, toggle boolean options, set numeric values (timers, delays), change enum settings (rehide strategy, %@ Bar location), and modify per-display configurations. This includes auto-rehide, show on click/hover/scroll/double-click, %@ Bar, hide application menus, enable always-hidden section, show tooltips, and diagnostic logging." : {
      "comment" : "A description of what whitelisted apps can do.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Whitelisted apps can read settings, toggle boolean options, set numeric values (timers, delays), change enum settings (rehide strategy, %1$@ Bar location), and modify per-display configurations. This includes auto-rehide, show on click/hover/scroll/double-click, %2$@ Bar, hide application menus, enable always-hidden section, show tooltips, and diagnostic logging."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホワイトリストに登録されたアプリは、設定の読み取り、ブール値オプションの切り替え、数値の設定（タイマー、遅延）、列挙型設定（再非表示戦略、%1$@ バーの位置）の変更、およびディスプレイごとの設定の変更が可能です。これには、自動再非表示、クリック/ホバー/スクロール/ダブルクリックで表示、%2$@ バー、アプリケーションメニューの非表示、「常に非表示」セクションの有効化、ツールチップの表示、および診断ログが含まれます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "白名单应用可以读取设置、切换布尔选项、设置数值（计时器、延迟）、更改枚举设置（重新隐藏策略、%1$@ 栏位置），并修改每台显示器的配置。包括自动重新隐藏、点击/悬停/滚动/双击显示、%2$@ 栏、隐藏应用菜单、启用“永久隐藏”区域、显示提示框和诊断日志。"
          }
        }
      }
    },
    "Would you like to import your existing configuration?" : {
      "comment" : "A question displayed to the user when they first open the app, asking if they would like to import their existing configuration.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "既存の設定をインポートしますか？"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "是否导入现有配置？"
          }
        }
      }
    },
    "Writes detailed debug logs to a file for troubleshooting. Log files are saved to ~/Library/Logs/Veil/. Disable when not needed to avoid unnecessary disk writes." : {
      "comment" : "A description of the diagnostic logging feature.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "トラブルシューティング用に詳細なデバッグログをファイルに書き込みます。ログファイルは ~/Library/Logs/Veil/ に保存されます。不要な場合は無効にして、余計なディスク書き込みを避けてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将详细的调试日志写入文件以便进行故障排除。日志文件保存在 ~/Library/Logs/Veil/ 目录下。如果不需要此功能，请禁用它以避免不必要的磁盘写入。"
          }
        }
      }
    },
    "You can remove apps from this list at any time to revoke their access." : {
      "comment" : "A description of how to remove apps from the whitelist.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このリストからアプリをいつでも削除することで、そのアクセス権を取り消すことができます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可随时将应用从列表中移除，以取消其访问权限。"
          }
        }
      }
    },
    "Clear All" : {
      "comment" : "A button that removes saved settings for all disconnected displays.",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
